# =============================================================================
# ZenBot Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to git. It's in .gitignore.
# Credentials are stored in the OS keychain at runtime, but env vars
# can be used for Docker deployments where no keychain is available.
# =============================================================================

# --- General ---
ZENBOT_LOG_LEVEL=INFO
ZENBOT_LOG_JSON=true
ZENBOT_LOG_FILE=true
ZENBOT_MAX_HISTORY=20
ZENBOT_SYSTEM_PROMPT="You are ZenBot, a helpful and secure AI assistant."

# --- LLM Provider ---
# Options: claude, openai, local
ZENBOT_LLM__PROVIDER=claude
ZENBOT_LLM__MODEL=claude-sonnet-4-20250514
ZENBOT_LLM__TEMPERATURE=0.7
ZENBOT_LLM__MAX_TOKENS=4096

# API Keys (set the one matching your provider)
ZENBOT_LLM_API_KEY=
# ZENBOT_LLM_API_KEY=sk-...          # OpenAI
# ZENBOT_LOCAL_LLM_URL=http://ollama:11434/v1  # For local models

# --- Telegram ---
ZENBOT_TELEGRAM__ENABLED=false
ZENBOT_TELEGRAM_BOT_TOKEN=

# --- Discord ---
ZENBOT_DISCORD__ENABLED=false
ZENBOT_DISCORD_BOT_TOKEN=

# --- WhatsApp ---
ZENBOT_WHATSAPP__ENABLED=false
ZENBOT_WHATSAPP_ACCESS_TOKEN=
ZENBOT_WHATSAPP_PHONE_NUMBER_ID=

# --- Signal ---
ZENBOT_SIGNAL__ENABLED=false
ZENBOT_SIGNAL_ACCOUNT=
ZENBOT_SIGNAL_CLI_URL=http://signal-cli:7583

# --- Slack ---
ZENBOT_SLACK__ENABLED=false
ZENBOT_SLACK_BOT_TOKEN=
ZENBOT_SLACK_APP_TOKEN=

# --- Microsoft Teams ---
ZENBOT_TEAMS__ENABLED=false
ZENBOT_TEAMS_APP_ID=
ZENBOT_TEAMS_APP_PASSWORD=

# --- iMessage ---
# macOS only, no credentials needed
ZENBOT_IMESSAGE__ENABLED=false

# --- Rate Limiting ---
ZENBOT_RATE_LIMIT__USER_CAPACITY=10.0
ZENBOT_RATE_LIMIT__USER_REFILL_RATE=1.0
ZENBOT_RATE_LIMIT__GLOBAL_CAPACITY=50.0
ZENBOT_RATE_LIMIT__GLOBAL_REFILL_RATE=10.0

# --- Redis (optional, for multi-instance) ---
ZENBOT_REDIS_URL=redis://redis:6379/0

# --- Dashboard (optional) ---
ZENBOT_DASHBOARD_HOST=0.0.0.0
ZENBOT_DASHBOARD_PORT=8082
# Auto-generated if not set:
# ZENBOT_DASHBOARD_API_TOKEN=

# --- Webhook Server ---
ZENBOT_WEBHOOK_HOST=0.0.0.0
ZENBOT_WEBHOOK_PORT=8080

# --- Healthcheck ---
ZENBOT_HEALTHCHECK_PORT=8081
