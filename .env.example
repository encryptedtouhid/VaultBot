# =============================================================================
# VaultBot Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to git. It's in .gitignore.
# Credentials are stored in the OS keychain at runtime, but env vars
# can be used for Docker deployments where no keychain is available.
# =============================================================================

# --- General ---
VAULTBOT_LOG_LEVEL=INFO
VAULTBOT_LOG_JSON=true
VAULTBOT_LOG_FILE=true
VAULTBOT_MAX_HISTORY=20
VAULTBOT_SYSTEM_PROMPT="You are VaultBot, a helpful and secure AI assistant."

# --- LLM Provider ---
# Options: claude, openai, local
VAULTBOT_LLM__PROVIDER=claude
VAULTBOT_LLM__MODEL=claude-sonnet-4-20250514
VAULTBOT_LLM__TEMPERATURE=0.7
VAULTBOT_LLM__MAX_TOKENS=4096

# API Keys (set the one matching your provider)
VAULTBOT_LLM_API_KEY=
# VAULTBOT_LLM_API_KEY=sk-...          # OpenAI
# VAULTBOT_LOCAL_LLM_URL=http://ollama:11434/v1  # For local models

# --- Telegram ---
VAULTBOT_TELEGRAM__ENABLED=false
VAULTBOT_TELEGRAM_BOT_TOKEN=

# --- Discord ---
VAULTBOT_DISCORD__ENABLED=false
VAULTBOT_DISCORD_BOT_TOKEN=

# --- WhatsApp ---
VAULTBOT_WHATSAPP__ENABLED=false
VAULTBOT_WHATSAPP_ACCESS_TOKEN=
VAULTBOT_WHATSAPP_PHONE_NUMBER_ID=

# --- Signal ---
VAULTBOT_SIGNAL__ENABLED=false
VAULTBOT_SIGNAL_ACCOUNT=
VAULTBOT_SIGNAL_CLI_URL=http://signal-cli:7583

# --- Slack ---
VAULTBOT_SLACK__ENABLED=false
VAULTBOT_SLACK_BOT_TOKEN=
VAULTBOT_SLACK_APP_TOKEN=

# --- Microsoft Teams ---
VAULTBOT_TEAMS__ENABLED=false
VAULTBOT_TEAMS_APP_ID=
VAULTBOT_TEAMS_APP_PASSWORD=

# --- iMessage ---
# macOS only, no credentials needed
VAULTBOT_IMESSAGE__ENABLED=false

# --- Rate Limiting ---
VAULTBOT_RATE_LIMIT__USER_CAPACITY=10.0
VAULTBOT_RATE_LIMIT__USER_REFILL_RATE=1.0
VAULTBOT_RATE_LIMIT__GLOBAL_CAPACITY=50.0
VAULTBOT_RATE_LIMIT__GLOBAL_REFILL_RATE=10.0

# --- Redis (optional, for multi-instance) ---
VAULTBOT_REDIS_URL=redis://redis:6379/0

# --- Dashboard (optional) ---
VAULTBOT_DASHBOARD_HOST=0.0.0.0
VAULTBOT_DASHBOARD_PORT=8082
# Auto-generated if not set:
# VAULTBOT_DASHBOARD_API_TOKEN=

# --- Webhook Server ---
VAULTBOT_WEBHOOK_HOST=0.0.0.0
VAULTBOT_WEBHOOK_PORT=8080

# --- Healthcheck ---
VAULTBOT_HEALTHCHECK_PORT=8081
